#include "rngForAes.h"


void SecureComms_GenerateNewIV(void) {

    for (int i = 0; i < 4; i++) {
        uint32_t random_val = 0;

        // Zabezpieczamy się na wypadek, gdyby RNG miało problem ze sprzętem
        if (HAL_RNG_GenerateRandomNumber(&hrng, &random_val) == HAL_OK) {
            pInitVectAES[i] = random_val;
        } else {
            Error_Handler();
        }
    }
}
